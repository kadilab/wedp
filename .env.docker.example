# Copy this file to ".env" (same folder as docker-compose.yml) and fill in
# real values before running: docker compose up -d --build

# ---- Database ----
DB_NAME=wedding_invite
DB_USER=wedding_app
DB_PASSWORD=change_me_strong_password
DB_ROOT_PASSWORD=change_me_root_password

# ---- Auth ----
JWT_SECRET=change_me_long_random_secret
JWT_EXPIRES_IN=7d

# ---- Domain (must already point to this VPS - A record) ----
# Caddy automatically requests and renews a Let's Encrypt HTTPS certificate
# for this domain. Both the dashboard and the check-in app (at /checkin/)
# are served from it on the standard 80/443 ports.
DOMAIN=winvite.pro
ACME_EMAIL=you@example.com

# ---- Public URL used by the backend (CORS, links in emails) ----
FRONTEND_URL=https://winvite.pro

# ---- Email (SMTP) - optional, leave blank to disable emails ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@weddinginvite.pro

# ---- Seed demo data on first start (admin@weddinginvite.pro / demo@weddinginvite.pro) ----
# Set to true only on the very first deploy, then back to false.
RUN_SEED=false
