# Copy this file to ".env" (same folder as docker-compose.yml) and fill in
# real values before running: docker compose up -d --build

# ---- Database ----
DB_NAME=wedding_invite
DB_USER=wedding_app
DB_PASSWORD=change_me_strong_password
DB_ROOT_PASSWORD=change_me_root_password

# ---- Auth ----
JWT_SECRET=change_me_long_random_secret
JWT_EXPIRES_IN=7d

# ---- Public URL ----
# IP or domain your VPS is reachable on, e.g. http://203.0.113.10
FRONTEND_URL=http://YOUR_VPS_IP

# ---- Port exposed on the host by the frontend/nginx container ----
HTTP_PORT=80

# ---- Email (SMTP) - optional, leave blank to disable emails ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@weddinginvite.pro

# ---- Seed demo data on first start (admin@weddinginvite.pro / demo@weddinginvite.pro) ----
# Set to true only on the very first deploy, then back to false.
RUN_SEED=false
