{
	# Falls back to a placeholder if ACME_EMAIL isn't set, so a missing env
	# var never breaks Caddyfile parsing - it's only used for Let's Encrypt
	# expiry notices, not required for HTTPS to work.
	email {$ACME_EMAIL:admin@example.com}
}

{$DOMAIN} {
	encode gzip

	# Check-in mobile PWA, served under the same domain/port so users never
	# need to type a different port - https://yourdomain/checkin/
	# Bare /checkin (no trailing slash) doesn't match /checkin/* below, so
	# redirect it first - otherwise the link from the homepage falls through
	# to the frontend and the check-in app is never reached.
	redir /checkin /checkin/ 308

	handle_path /checkin/* {
		reverse_proxy checkin:80
	}

	# Everything else: the main dashboard, which itself proxies /api,
	# /uploads, /templates and /socket.io to the backend container.
	handle {
		reverse_proxy frontend:80
	}
}
